---
import type { FileRecord } from '@/db/types'
import FilePage from '@/components/article-view/FilePage.astro'
import { readByPath } from '@/db/markdown'
import { retriveRss } from '@/lib/utils/rss'

const { slug } = Astro.params

if (slug === 'rss.xml') {
  return retriveRss(Astro)
}

const path = `/${slug || ''}`
const maybePage: FileRecord | undefined = await readByPath(Astro.locals.runtime?.env, path)

if (!maybePage) {
  return Astro.redirect(`/404?source=${encodeURIComponent(Astro.url.pathname)}`)
}
if (maybePage.private) {
  if (!Astro.locals.session.role) {
    return Astro.redirect(`/guest-login?id=${maybePage.id}`)
  }
}

---

<FilePage article={maybePage} />
