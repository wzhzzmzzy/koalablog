---
import List from '@/components/dashboard/list.astro'
import { MarkdownSource } from '@/db'
import Layout from '@/layouts/home.astro'
import { parseIndexListParams } from '@/lib/utils/list-params'

const { source, year, tag } = parseIndexListParams(Astro.url.searchParams)
const listLabel = source === MarkdownSource.Memo ? 'Memos' : 'Posts'
const pageTitle = tag ? `${listLabel} - #${tag}` : undefined
---

<Layout title={pageTitle}>
  <List source={source} tag={tag} year={year} />
</Layout>
