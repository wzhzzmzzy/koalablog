---
import Page from '@/components/editor/Page.svelte'
import { MarkdownSource } from '@/db'
import { generateMemoTitle, justReadAll } from '@/db/markdown'
import { initFileRecord } from '@/db/types'
import DashboardLayout from '@/layouts/dashboard.astro'

const url = Astro.url
const id = Number(url.searchParams.get('id') || '0')
const path = url.searchParams.get('path')
const isMemo = url.searchParams.has('memo')

let article = initFileRecord()

let initialItems: Awaited<ReturnType<typeof justReadAll>> = []
initialItems = await justReadAll(Astro.locals.runtime?.env)

if (id) {
  const found = initialItems.find(i => i.id === id)
  if (found) {
    article = found
  }
}
else if (path) {
  const found = initialItems.find(i => !i.deletedAt && i.path === path)
  if (found) {
    article = found
  }
}
else if (isMemo) {
  article = initFileRecord(MarkdownSource.Memo)
  const memoTitle = await generateMemoTitle(Astro.locals.runtime?.env)
  article.title = memoTitle
  article.path = `/memo/${memoTitle}`
  article.private = true
}

const userAgent = Astro.request.headers.get('user-agent') || ''
const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(userAgent);
---

<DashboardLayout title={`[Editor] ${article.title}`} showHeader={false}>
  <Page client:load initialMarkdown={article} initialItems={initialItems} isMobile={isMobile} />
</DashboardLayout>
