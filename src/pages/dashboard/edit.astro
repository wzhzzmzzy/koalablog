---
import type { FileRecord } from '@/db/types'
import Page from '@/components/editor/Page.svelte'
import { justReadAll } from '@/db/markdown'
import { readTemplateCatalog } from '@/db/template-catalog'
import DashboardLayout from '@/layouts/dashboard.astro'

const url = Astro.url
const id = Number(url.searchParams.get('id') || '0')
const path = url.searchParams.get('path')
let file: FileRecord | null = null

let initialItems: Awaited<ReturnType<typeof justReadAll>> = []
initialItems = await justReadAll(Astro.locals.runtime?.env)

if (id) {
  const found = initialItems.find(i => i.id === id)
  if (found) {
    file = found
  }
}
else if (path) {
  const found = initialItems.find(i => !i.deletedAt && i.path === path)
  if (found) {
    file = found
  }
}
const catalog = await readTemplateCatalog(Astro.locals.runtime?.env)
const templatePrefixes = catalog.status === 'ready' ? catalog.catalog.templates.map(template => template.prefix) : []

const userAgent = Astro.request.headers.get('user-agent') || ''
const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(userAgent);
---

<DashboardLayout title={`[Editor] ${file?.title ?? 'Files'}`} showHeader={false}>
  <Page client:load initialFile={file} initialItems={initialItems} {templatePrefixes} isMobile={isMobile} />
</DashboardLayout>
