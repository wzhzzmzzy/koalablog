---
import OnboardingForm from '@/components/onboarding/index.svelte'
import { resetD1ForOnboarding } from '@/db/onboarding'
import Layout from '@/layouts/layout.astro'

// #if CF_PAGES
import initSql from '../../migrations/0000_init.sql?raw'
import templateCatalogSql from '../../migrations/0001_creation_template_catalog.sql?raw'
import fileSourceSql from '../../migrations/0002_file_source_schema.sql?raw'
// #endif

const env = Astro.locals.runtime?.env || {}
const config = Astro.locals.config

if (config._runtime?.ready) {
  return Astro.redirect('/')
}

// #if CF_PAGES
if (env.DATA_SOURCE && env.DATA_SOURCE === 'd1') {
  await resetD1ForOnboarding(env, [initSql, templateCatalogSql, fileSourceSql])
}
// #endif
---


<Layout>
  <OnboardingForm client:load />
</Layout>
