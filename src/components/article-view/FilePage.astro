---
import type { FileRecord } from '@/db/types'
import { readActivePaths } from '@/db/markdown'
import Layout from '@/layouts/home.astro'
import { renderIt } from '@/lib/markdown/render-it'
import ArticleClient from './client.astro'
import ArticleView from './index.astro'

interface Props {
  article: FileRecord
  title?: string
}

const { article, title = article.title } = Astro.props
const pageConfig = Astro.locals.config.pageConfig
const isBigArticle = article.content.length > 1000
const activePaths = await readActivePaths(Astro.locals.runtime?.env)
const { content, renderLangSet } = await renderIt(isBigArticle, article, pageConfig.theme, activePaths)
const firstParagraph = /<p>(.*?)<\/p>/.exec(content)
---

<Layout title={title} desc={firstParagraph?.[1]}>
  {
    !isBigArticle
      ? <ArticleView article={article} content={content} />
      : <ArticleClient article={article} content={content} renderLangSet={renderLangSet} {activePaths} />
  }
</Layout>
